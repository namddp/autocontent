# Database
POSTGRES_DB=family_maid_dev
POSTGRES_USER=family_maid
POSTGRES_PASSWORD=change_me_in_production
DATABASE_URL="postgresql://family_maid:change_me_in_production@localhost:5432/family_maid_dev"

# Redis
REDIS_URL="redis://:password@localhost:6379"
REDIS_PASSWORD=change_me_in_production

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_in_production
MINIO_BUCKET_NAME=family-maid
MINIO_USE_SSL=false

# App
NODE_ENV=development
API_PORT=3001
APP_NAME=FamilyMaid Internal
DOMAIN=localhost

# CORS
CORS_ORIGINS=http://localhost:3000

# Next.js frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
