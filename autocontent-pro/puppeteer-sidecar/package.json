{
  "name": "puppeteer-sidecar",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.js",
  "bin": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "build:win": "pkg --target node18-win-x64 --output ../src-tauri/binaries/puppeteer-sidecar-x86_64-pc-windows-msvc.exe src/index.js",
    "build:mac-arm": "pkg --target node18-macos-arm64 --output ../src-tauri/binaries/puppeteer-sidecar-aarch64-apple-darwin src/index.js",
    "build:mac-x64": "pkg --target node18-macos-x64 --output ../src-tauri/binaries/puppeteer-sidecar-x86_64-apple-darwin src/index.js"
  },
  "dependencies": {
    "puppeteer-core": "^24.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "pkg": {
    "assets": [],
    "targets": ["node18-win-x64", "node18-macos-arm64", "node18-macos-x64"]
  }
}
